// ===========================================================================
// Zero-Touch ML — Declarative Jenkins Pipeline
// ===========================================================================
// Stages:
//   1. Checkout
//   2. Setup Python Environment
//   3. Train Model
//   4. Run Tests
//   5. Build Docker Image
//   6. Security Scan (Trivy)
//   7. Push Image to Registry
//   8. Deploy to Kubernetes via Helm
//   9. Verify Deployment
// ===========================================================================

pipeline {
    agent any

    environment {
        IMAGE_NAME       = 'zero-touch-ml'
        IMAGE_TAG        = "${env.BUILD_NUMBER}"
        HELM_RELEASE     = 'zero-touch-ml'
        HELM_CHART       = 'helm/zero-touch-ml'
        K8S_NAMESPACE    = 'default'
        KUBECONFIG       = '/var/jenkins_home/.kube/config'
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        // ---------------------------------------------------------------
        // Stage 1 — Checkout
        // ---------------------------------------------------------------
        stage('Checkout') {
            steps {
                echo 'Pulling latest source code...'
                cleanWs()
                checkout scm
            }
        }

        // ---------------------------------------------------------------
        // Stage 2 — Setup Python Environment
        // ---------------------------------------------------------------
        stage('Setup Python Environment') {
            steps {
                echo 'Setting up Python virtual environment...'
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r service/requirements.txt
                    pip install pytest flake8 black
                '''
            }
        }

        // ---------------------------------------------------------------
        // Stage 3 — Train Model
        // ---------------------------------------------------------------
        stage('Train Model') {
            steps {
                echo 'Training ML model...'
                sh '''
                    . venv/bin/activate
                    python model/train.py
                '''
            }
            post {
                success {
                    archiveArtifacts artifacts: 'model/artifacts/**', fingerprint: true
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 4 — Run Tests
        // ---------------------------------------------------------------
        stage('Run Tests') {
            steps {
                echo 'Running test suite...'
                sh '''
                    . venv/bin/activate
                    python -m pytest tests/ -v --tb=short --junitxml=reports/test-results.xml
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'reports/test-results.xml'
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 5 — Build Docker Image
        // ---------------------------------------------------------------
        stage('Build Docker Image') {
            steps {
                withCredentials([string(credentialsId: 'docker-hub-username', variable: 'DOCKER_USER')]) {
                    sh 'docker build -t $DOCKER_USER/$IMAGE_NAME:$IMAGE_TAG -t $DOCKER_USER/$IMAGE_NAME:latest .'
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 6 — Security Scan (Trivy)
        // ---------------------------------------------------------------
        stage('Security Scan') {
            steps {
                echo 'Scanning image for vulnerabilities with Trivy...'
                withCredentials([string(credentialsId: 'docker-hub-username', variable: 'DOCKER_USER')]) {
                    sh 'trivy image --severity HIGH,CRITICAL --exit-code 0 --format table $DOCKER_USER/$IMAGE_NAME:$IMAGE_TAG'
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 7 — Push Image to Registry
        // ---------------------------------------------------------------
        stage('Push Image') {
            steps {
                echo 'Pushing image to Docker Hub...'
                withCredentials([
                    string(credentialsId: 'docker-hub-username', variable: 'DOCKER_USER'),
                    string(credentialsId: 'docker-hub-password', variable: 'DOCKER_PASS')
                ]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push $DOCKER_USER/$IMAGE_NAME:$IMAGE_TAG
                        docker push $DOCKER_USER/$IMAGE_NAME:latest
                    '''
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 8 — Deploy to Kubernetes via Helm
        // ---------------------------------------------------------------
        stage('Deploy via Helm') {
            when {
                expression {
                    return sh(script: 'kubectl cluster-info > /dev/null 2>&1', returnStatus: true) == 0
                }
            }
            steps {
                withCredentials([string(credentialsId: 'docker-hub-username', variable: 'DOCKER_USER')]) {
                    sh '''
                        helm upgrade --install $HELM_RELEASE $HELM_CHART \
                            --set image.repository=$DOCKER_USER/$IMAGE_NAME \
                            --set image.tag=$IMAGE_TAG \
                            --namespace $K8S_NAMESPACE \
                            --wait \
                            --timeout 120s
                    '''
                }
            }
        }

        // ---------------------------------------------------------------
        // Stage 9 — Verify Deployment
        // ---------------------------------------------------------------
        stage('Verify Deployment') {
            when {
                expression {
                    return sh(script: 'kubectl cluster-info > /dev/null 2>&1', returnStatus: true) == 0
                }
            }
            steps {
                echo 'Verifying deployment rollout...'
                sh '''
                    kubectl rollout status deployment/$HELM_RELEASE \
                        --namespace $K8S_NAMESPACE \
                        --timeout=120s
                '''
                echo 'Checking pod status...'
                sh 'kubectl get pods -l app.kubernetes.io/name=$IMAGE_NAME -n $K8S_NAMESPACE'
            }
        }
    }

    // -------------------------------------------------------------------
    // Post-pipeline actions
    // -------------------------------------------------------------------
    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed — check logs above.'
        }
        always {
            echo 'Cleaning up workspace...'
            sh 'docker logout || true'
            cleanWs()
        }
    }
}
