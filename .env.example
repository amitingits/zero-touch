# ===========================================================================
# Zero-Touch ML — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ===========================================================================

# Docker Hub
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Flask
PORT=5000
FLASK_ENV=production

# Kubernetes
K8S_NAMESPACE=default
HELM_RELEASE=zero-touch-ml
